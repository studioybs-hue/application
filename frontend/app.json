{
  "expo": {
    "name": "Cinémariés",
    "slug": "cinemaries",
    "version": "1.6.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cinemaries",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fr.cinemaries.app",
      "buildNumber": "2",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Recherche les Chromecast et TV connectées sur votre Wi-Fi pour la diffusion vidéo.",
        "NSBonjourServices": [
          "_googlecast._tcp",
          "_googlecast._tcp"
        ],
        "NSPhotoLibraryUsageDescription": "Choisir une photo pour votre mariage.",
        "NSCameraUsageDescription": "Prendre une photo pour votre mariage."
      }
    },
    "android": {
      "package": "fr.cinemaries.app",
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE",
        "CHANGE_WIFI_MULTICAST_STATE",
        "INTERNET",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.NEARBY_WIFI_DEVICES",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE",
        "CHANGE_WIFI_MULTICAST_STATE",
        "INTERNET",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.NEARBY_WIFI_DEVICES",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0A"
        }
      ],
      "expo-web-browser",
      [
        "react-native-google-cast",
        {
          "iosReceiverAppId": "CC1AD845",
          "androidReceiverAppId": "CC1AD845"
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "1ec31350-99d2-430a-bf45-b9f4c2ee4b27"
      },
      "router": {}
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1ec31350-99d2-430a-bf45-b9f4c2ee4b27"
    }
  }
}
