{
  "expo": {
    "name": "Cinémariés",
    "slug": "cinemaries",
    "version": "1.6.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cinemaries",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fr.cinemaries.app",
      "buildNumber": "3",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Recherche les Chromecast et TV connectées sur votre Wi-Fi pour la diffusion vidéo.",
        "NSBonjourServices": [
          "_googlecast._tcp"
        ],
        "NSPhotoLibraryUsageDescription": "Choisir une photo pour votre mariage.",
        "NSCameraUsageDescription": "Prendre une photo pour votre mariage.",
        "NSUserNotificationsUsageDescription": "Vous prévenir quand votre film est en ligne."
      }
    },
    "android": {
      "package": "fr.cinemaries.app",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE",
        "CHANGE_WIFI_MULTICAST_STATE",
        "INTERNET",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.NEARBY_WIFI_DEVICES",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0A"
        }
      ],
      "expo-web-browser",
      [
        "react-native-google-cast",
        {
          "iosReceiverAppId": "CC1AD845",
          "androidReceiverAppId": "CC1AD845"
        }
      ],
      "expo-video",
      [
        "expo-notifications",
        {
          "color": "#D4AF37",
          "defaultChannel": "default"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
